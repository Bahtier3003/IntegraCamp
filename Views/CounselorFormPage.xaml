<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IntegraCamp.Views.CounselorFormPage"
             Title="Вожатый">

    <ScrollView>
        <StackLayout Padding="20" Spacing="15">

            <Entry x:Name="FullNameEntry" Placeholder="ФИО *" />

            <Entry x:Name="PhoneEntry" Placeholder="Телефон *" Keyboard="Telephone"/>

            <Picker x:Name="BuildingPicker" Title="Корпус *">
                <Picker.Items>
                    <x:String>Солнечная</x:String>
                    <x:String>Морская</x:String>
                    <x:String>Жемчужная</x:String>
                    <x:String>Звездная</x:String>
                    <x:String>Изумрудная</x:String>
                </Picker.Items>
            </Picker>

            <Entry x:Name="SquadEntry" Placeholder="Номер отряда (оставьте пустым если свободен)" Keyboard="Numeric"/>

            <Entry x:Name="ChildrenCountEntry" Placeholder="Количество детей *" Keyboard="Numeric" Text="0"/>

            <Entry x:Name="RoomEntry" Placeholder="Комната (101-108, 201-212, 301-312) *"/>

            <Switch x:Name="StatusSwitch" IsToggled="False"/>
            <Label Text="{Binding Source={x:Reference StatusSwitch}, Path=IsToggled, Converter={StaticResource BoolToStringConverter}}"/>

            <Button x:Name="SaveButton" Text="Сохранить" Clicked="OnSaveClicked" 
                    BackgroundColor="#2196F3" TextColor="White"/>

            <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False"/>

        </StackLayout>
    </ScrollView>
</ContentPage>